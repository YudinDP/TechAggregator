generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  fullName     String?
  role         String       @default("user")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  comparisons  Comparison[]
  favorites    Favorite[]
  requests     Request[]
  reviews      Review[]
  viewLogs     ViewLog[]
  searchLogs   SearchLog[]
  avatarUrl    String?
}

model Product {
  id             Int            @id @default(autoincrement())
  name           String
  category       String
  description    String?
  imageUrl       String?
  rating         Float          @default(0.0)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  comparisons    Comparison[]
  favorites      Favorite[]
  prices         Price[]
  priceHistories PriceHistory[]
  specs          ProductSpec[]
  reviews        Review[]
  viewLogs       ViewLog[]
}

model ProductSpec {
  id        Int     @id @default(autoincrement())
  productId Int
  specKey   String
  specValue String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Price {
  id         Int      @id @default(autoincrement())
  productId  Int
  storeName  String
  sellerName String?
  price      Int
  url        String?
  recordedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Favorite {
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

model Comparison {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id          Int       @id @default(autoincrement())
  userId      Int? // Может быть null
  productId   Int // Обязательный внешний ключ
  userName    String? // Может быть null
  rating      Int // Обязательное: оценка
  comment     String? // Опциональное: текст
  isApproved  Boolean   @default(false) // Статус одобрения
  status      String    @default("pending") // Статус модерации
  adminNotes  String? // Примечания администратора
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  processedAt DateTime?

  // Связи
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Request {
  id          Int       @id @default(autoincrement())
  userId      Int?
  productName String
  description String?
  url         String?
  comment     String?
  category    String?
  status      String    @default("pending")
  adminNotes  String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  user        User?     @relation(fields: [userId], references: [id])
}

model PriceHistory {
  id        Int       @id @default(autoincrement())
  productId Int
  storeName String    @db.VarChar(255)
  sellerName String?  @db.VarChar(255)
  price     Decimal   @db.Decimal(10, 2)
  date      DateTime? @default(now()) @db.Timestamp(6)
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pricehistory_product")

  @@index([date], map: "idx_pricehistory_date")
  @@index([productId, storeName], map: "idx_pricehistory_product_store")
}

model ViewLog {
  id        Int      @id @default(autoincrement())
  userId    Int? // Может быть null для анонимных пользователей
  productId Int // ID просмотренного товара
  viewedAt  DateTime @default(now())

  // Связи с обратными ссылками (обязательно для Prisma)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([viewedAt])
}

// НОВАЯ МОДЕЛЬ: История поисковых запросов
model SearchLog {
  id        Int      @id @default(autoincrement())
  query     String // Текст запроса
  userId    Int? // Кто искал (может быть анонимно)
  createdAt DateTime @default(now())

  // Связь с пользователем (опционально)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([query])
  @@index([createdAt])
}
